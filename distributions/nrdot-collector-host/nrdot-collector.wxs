<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="NRDOT Collector Host"
    Language="1033"
    Version="1.11.1.0"
    Manufacturer="New Relic"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">

    <Package
      InstallerVersion="200"
      Compressed="yes"
      InstallScope="perMachine"
      Description="NRDOT Collector Host with Oracle and SQL Server support"
      Comments="Supports --config flag: nrdot-collector-host.exe --config=path\to\config.yaml" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of NRDOT Collector Host is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="ProductFeature" Title="NRDOT Collector Host" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="ConfigFile" />
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="NRDOT Collector Host">
          <Component Id="MainExecutable" Guid="12345678-ABCD-EF12-3456-789ABCDEF012">
            <File
              Id="nrdotcollectorhostEXE"
              Source="dist/nrdot-collector-host_windows_amd64_v1/nrdot-collector-host.exe"
              KeyPath="yes" />
          </Component>
          <Component Id="ConfigFile" Guid="23456789-BCDE-F123-4567-89ABCDEF0123">
            <File
              Id="configYAML"
              Source="distributions/nrdot-collector-host/config.yaml"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

  </Product>
</Wix>
